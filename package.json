{
  "name": "design-hours-tracker",
  "version": "1.4.2",
  "description": "Design Hours Tracker for Wiginton Corporation",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.wiginton.design-hours-tracker",
    "productName": "Design Hours Tracker",
    "copyright": "Wiginton Corporation",
    "icon": "src/icon.ico",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "sign": null,
      "signingHashAlgorithms": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**",
      "scripts/**",
      "assets/**"
    ],
    "asarUnpack": [
      "scripts/**",
      "assets/**"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "dsmithwfs",
      "repo": "design-hours-tracker"
    }
  }
}
