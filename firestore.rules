rules_version = '2';

// Each signed-in user can read and write ONLY their own data subtree.
// The app stores everything under users/{uid}/sync/data (see firebase-sync.js).
// No rule matches any other path, so all other reads/writes are denied.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}

// Deploy:
//   - Firebase Console → Firestore Database → Rules → paste → Publish, OR
//   - firebase deploy --only firestore:rules   (requires firebase login)
//
// Verify these are live: an authenticated user must NOT be able to read
// users/<someone-else-uid>/sync/data. If the database is still in test mode,
// these rules are NOT enforced — publish them before relying on sync privacy.
